# Discord Bot Token (required)
# Create a bot at https://discord.com/developers/applications and copy the token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID (required)
# Right-click the channel in Discord > "Copy Channel ID" (Developer Mode must be enabled)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# GitHub Webhook Secret (recommended)
# Set this to a random string, then use the same value when creating the webhook on GitHub
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Port for the webhook HTTP server (optional, defaults to 3000)
PORT=3000
